# =============================================
#      TOURISM PLATFORM - SPRING BOOT BACKEND
#   Copy this file to application.properties
#      and fill in your own values before running
# =============================================


# --------------------------------------------
# APPLICATION
# --------------------------------------------

spring.application.name=


# --------------------------------------------
# DATABASE
# --------------------------------------------

# MongoDB connection string (local or Atlas)
# Local:  mongodb://localhost:27017/tourism_db
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/tourism_db
spring.data.mongodb.uri=
spring.data.mongodb.database=

# Automatically create indexes defined in your entity classes
spring.data.mongodb.auto-index-creation=true


# --------------------------------------------
# EMAIL SERVICE (Gmail SMTP)
# --------------------------------------------

# Use Gmail SMTP to send booking confirmation emails
# Enable "App Passwords" in your Google account settings
spring.mail.host=smtp.gmail.com
spring.mail.port=587
spring.mail.username=
spring.mail.password=

# Required SMTP settings — keep these values as-is
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true
spring.mail.properties.mail.smtp.ssl.trust=smtp.gmail.com


# --------------------------------------------
# CLOUDINARY (Image Upload)
# --------------------------------------------

# Get these from https://cloudinary.com/console
cloudinary.cloud_name=
cloudinary.api_key=
cloudinary.api_secret=


# --------------------------------------------
# PAYPAL
# --------------------------------------------

# Get these from https://developer.paypal.com/dashboard
# mode: sandbox (testing) or live (production)
paypal.client-id=
paypal.client-secret=
paypal.mode=sandbox


# --------------------------------------------
# VNPAY (Vietnamese Payment Gateway)
# --------------------------------------------

# Get these from https://sandbox.vnpayment.vn/devreg
vnpay.tmn-code=
vnpay.hash-secret=


# --------------------------------------------
# GOOGLE OAUTH2
# --------------------------------------------

# Get these from https://console.cloud.google.com/apis/credentials
# Set redirect URI to match your frontend URL
spring.security.oauth2.client.registration.google.client-id=
spring.security.oauth2.client.registration.google.client-secret=
spring.security.oauth2.client.registration.google.redirect-uri=http://localhost:5174
