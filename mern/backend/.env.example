# =============================================
#         TOURISM PLATFORM - MERN BACKEND
#      Copy this file to .env and fill in
#         your own values before running
# =============================================


# --------------------------------------------
# SERVER
# --------------------------------------------

# Port the backend server will run on
PORT=3000

# URL of the frontend app (used for CORS)
CLIENT_URL=http://localhost:5173


# --------------------------------------------
# DATABASE
# --------------------------------------------

# MongoDB connection string (local or Atlas)
# Local:  mongodb://localhost:27017/tourism_db
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/tourism_db
MONGO_URI=


# --------------------------------------------
# AUTHENTICATION
# --------------------------------------------

# Secret key used to sign JWT tokens (use a long random string)
JWT_SECRET=


# --------------------------------------------
# CLOUDINARY (Image Upload)
# --------------------------------------------

# Get these from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=


# --------------------------------------------
# EMAIL SERVICE
# --------------------------------------------

# Gmail account used to send booking confirmation emails
# Enable "App Passwords" in your Google account settings
EMAIL_USERNAME=
EMAIL_PASSWORD=


# --------------------------------------------
# PAYPAL
# --------------------------------------------

# Get these from https://developer.paypal.com/dashboard
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=


# --------------------------------------------
# STRIPE
# --------------------------------------------

# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=


# --------------------------------------------
# PAYOS (Vietnamese Payment Gateway)
# --------------------------------------------

# Get these from https://payos.vn
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
